# Production — Ubuntu + 宝塔面板 + Docker Compose
# Copy to .env before: docker compose up -d --build
# 注意：宝塔已自带 Nginx，不要使用 docker compose --profile prod

# Required — change in production
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# DeepL (optional)
DEEPL_AUTH_KEY=

# CORS — 你的正式域名（须与浏览器访问地址一致）
CORS_ORIGIN=https://your-domain.com

# Web build: 宝塔 Nginx 反代后，前端用同源 API 路径
NEXT_PUBLIC_API_URL=/api/v1

# Docker 数据持久化（宝塔常见路径，可按站点目录调整）
DATA_DIR=/www/wwwroot/overbuild/data

# 以下端口仅本机 Docker 映射，勿在防火墙对外开放
API_PORT=3001
WEB_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
