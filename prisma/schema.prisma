generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive
}

enum Locale {
  zh
  fr
  en
}

enum AuditAction {
  create
  update
  delete
  export
  approve
  reject
  login
  logout
}

enum ProjectStatus {
  planning
  active
  suspended
  completed
}

enum MilestoneStatus {
  pending
  completed
  overdue
}

enum TaskStatus {
  pending
  in_progress
  completed
}

enum ApprovalType {
  purchase_request
  payment
  reimbursement
  contract
  drawing
}

enum ApprovalStatus {
  pending
  approved
  rejected
  cancelled
}

enum ApprovalRecordAction {
  approve
  reject
}

enum NotificationType {
  approval
  inventory
  procurement
  finance
  system
}

enum StockTransactionType {
  inbound
  outbound
  adjustment
}

enum MaterialDiscipline {
  civil
  mep
  finishing
  general
}

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  passwordHash String     @map("password_hash")
  name         String
  email        String?
  phone        String?
  locale       Locale     @default(zh)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  userRoles       UserRole[]
  auditLogs       AuditLog[]
  managedProjects Project[]       @relation("ProjectManager")
  projectMembers  ProjectMember[]
  assignedTasks   ProjectTask[]   @relation("TaskAssignee")
  initiatedApprovals ApprovalInstance[] @relation("ApprovalInitiator")
  approvalRecords    ApprovalRecord[]   @relation("ApprovalApprover")
  notifications      Notification[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  module    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  projectId String?  @map("project_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, projectId])
  @@map("user_roles")
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?     @map("user_id")
  action     AuditAction
  module     String
  resource   String
  resourceId String?     @map("resource_id")
  payload    Json?
  ip         String?
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  key         String   @id
  value       Json
  description String?
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model UserPreference {
  userId            String   @id @map("user_id")
  locale            Locale   @default(zh)
  theme             String   @default("system")
  notificationPrefs Json?    @map("notification_prefs")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("user_preferences")
}

model Project {
  id          String        @id @default(uuid())
  code        String        @unique
  name        String
  nameFr      String?       @map("name_fr")
  location    String?
  status      ProjectStatus @default(planning)
  startDate   DateTime?     @map("start_date") @db.Date
  endDate     DateTime?     @map("end_date") @db.Date
  description String?
  managerId   String        @map("manager_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  manager    User               @relation("ProjectManager", fields: [managerId], references: [id])
  zones      ProjectZone[]
  members    ProjectMember[]
  milestones ProjectMilestone[]
  tasks      ProjectTask[]
  approvals  ApprovalInstance[]
  stockTransactions StockTransaction[]
  materials  Material[]

  @@index([status])
  @@index([managerId])
  @@map("projects")
}

model ProjectZone {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  name        String
  nameFr      String?   @map("name_fr")
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   ProjectTask[]

  @@index([projectId])
  @@map("project_zones")
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectMilestone {
  id          String          @id @default(uuid())
  projectId   String          @map("project_id")
  name        String
  dueDate     DateTime?       @map("due_date") @db.Date
  completedAt DateTime?       @map("completed_at")
  status      MilestoneStatus @default(pending)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_milestones")
}

model ProjectTask {
  id        String     @id @default(uuid())
  projectId String     @map("project_id")
  code      String?
  name      String
  nameFr    String?    @map("name_fr")
  zoneId    String?    @map("zone_id")
  parentId  String?    @map("parent_id")
  startDate     DateTime?  @map("start_date") @db.Date
  endDate       DateTime?  @map("end_date") @db.Date
  laborCount    Int?       @map("labor_count")
  durationDays  Decimal?   @map("duration_days") @db.Decimal(10, 2)
  prerequisites String?
  predecessorId String?    @map("predecessor_id")
  assigneeId    String?    @map("assignee_id")
  showInGantt   Boolean    @default(true) @map("show_in_gantt")
  progress      Int        @default(0)
  status    TaskStatus @default(pending)
  sortOrder Int        @default(0) @map("sort_order")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zone         ProjectZone?  @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  parent       ProjectTask?  @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     ProjectTask[] @relation("TaskHierarchy")
  predecessor  ProjectTask?  @relation("TaskPredecessor", fields: [predecessorId], references: [id], onDelete: SetNull)
  successors   ProjectTask[] @relation("TaskPredecessor")
  assignee     User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([zoneId])
  @@index([parentId])
  @@index([predecessorId])
  @@index([assigneeId])
  @@map("project_tasks")
}

model ApprovalInstance {
  id          String         @id @default(uuid())
  code        String         @unique
  type        ApprovalType
  businessId  String         @map("business_id")
  projectId   String?        @map("project_id")
  initiatorId String         @map("initiator_id")
  status      ApprovalStatus @default(pending)
  currentNode Int            @default(1) @map("current_node")
  metadata    Json?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  initiator User              @relation("ApprovalInitiator", fields: [initiatorId], references: [id])
  project   Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  records   ApprovalRecord[]

  @@index([type])
  @@index([status])
  @@index([initiatorId])
  @@index([projectId])
  @@index([businessId, type])
  @@map("approval_instances")
}

model ApprovalRecord {
  id         String               @id @default(uuid())
  instanceId String               @map("instance_id")
  node       Int
  approverId String               @map("approver_id")
  action     ApprovalRecordAction
  comment    String?
  actedAt    DateTime             @default(now()) @map("acted_at")

  instance ApprovalInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  approver User             @relation("ApprovalApprover", fields: [approverId], references: [id])

  @@index([instanceId])
  @@index([approverId])
  @@map("approval_records")
}

model ApprovalTemplate {
  id        String       @id @default(uuid())
  type      ApprovalType
  name      String
  nodes     Json
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@index([type, isActive])
  @@map("approval_templates")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  content   String
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

model MaterialCategory {
  id          String             @id @default(uuid())
  code        String             @unique
  name        String
  discipline  MaterialDiscipline @default(general)
  description String?
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")

  materials Material[]

  @@index([discipline])
  @@map("material_categories")
}

model Material {
  id                     String    @id @default(uuid())
  code                   String
  name                   String
  spec                   String?
  brand                  String?
  model                  String?
  unit                   String
  categoryId             String    @map("category_id")
  projectId              String    @map("project_id")
  storageLocation        String?   @map("storage_location")
  warehouseId            String?   @map("warehouse_id")
  stock                  Decimal   @default(0) @db.Decimal(18, 4)
  minStock               Decimal?  @map("min_stock") @db.Decimal(18, 4)
  purchasePriceAmount    Decimal?  @map("purchase_price_amount") @db.Decimal(18, 4)
  purchasePriceCurrency  String?   @map("purchase_price_currency") @db.Char(3)
  imageUrl               String?   @map("image_url")
  supplierId             String?   @map("supplier_id")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  category        MaterialCategory      @relation(fields: [categoryId], references: [id])
  project         Project               @relation(fields: [projectId], references: [id])
  priceHistory    MaterialPriceHistory[]
  qrcode          MaterialQrcode?
  stockTransactions StockTransaction[]

  @@unique([projectId, code])
  @@index([categoryId])
  @@index([projectId])
  @@index([name])
  @@map("materials")
}

model MaterialPriceHistory {
  id          String   @id @default(uuid())
  materialId  String   @map("material_id")
  amount      Decimal  @db.Decimal(18, 4)
  currency    String   @db.Char(3)
  supplierId  String?  @map("supplier_id")
  effectiveAt DateTime @default(now()) @map("effective_at")
  createdAt   DateTime @default(now()) @map("created_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([materialId, effectiveAt])
  @@map("material_price_history")
}

model MaterialQrcode {
  id         String   @id @default(uuid())
  materialId String   @unique @map("material_id")
  qrcodeUrl  String   @map("qrcode_url")
  payload    String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@map("material_qrcodes")
}

model StockTransaction {
  id            String               @id @default(uuid())
  materialId    String               @map("material_id")
  type          StockTransactionType
  quantity      Decimal              @db.Decimal(18, 4)
  balanceAfter  Decimal?             @map("balance_after") @db.Decimal(18, 4)
  reference     String?
  warehouseId   String?              @map("warehouse_id")
  projectId     String?              @map("project_id")
  createdAt     DateTime             @default(now()) @map("created_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Restrict)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([materialId])
  @@index([projectId])
  @@index([createdAt])
  @@map("stock_transactions")
}
