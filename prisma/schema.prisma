generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive
}

enum Locale {
  zh
  fr
  en
}

enum AuditAction {
  create
  update
  delete
  export
  approve
  reject
  login
  logout
}

enum ProjectStatus {
  planning
  active
  suspended
  completed
}

enum MilestoneStatus {
  pending
  completed
  overdue
}

enum TaskStatus {
  pending
  in_progress
  completed
}

enum ApprovalType {
  purchase_request
  payment
  reimbursement
  contract
  drawing
}

enum ApprovalStatus {
  pending
  approved
  rejected
  cancelled
}

enum ApprovalRecordAction {
  approve
  reject
}

enum NotificationType {
  approval
  inventory
  procurement
  finance
  system
}

enum StockTransactionType {
  inbound
  outbound
  adjustment
}

enum MaterialDiscipline {
  civil
  mep
  finishing
  general
}

enum PurchaseRequestStatus {
  draft
  pending
  approved
  rejected
  ordered
}

enum PurchaseOrderStatus {
  draft
  confirmed
  partial
  received
  cancelled
}

enum QuotationStatus {
  draft
  quoted
  accepted
  rejected
}

enum WarehouseStatus {
  active
  inactive
}

enum StockDocumentStatus {
  draft
  confirmed
}

enum InboundType {
  purchase
  return
  adjustment
}

enum OutboundType {
  usage
  transfer
}

enum ContractType {
  construction
  procurement
  service
  other
}

enum ContractStatus {
  draft
  active
  completed
  terminated
}

enum ContractChangeType {
  amount
  period
  terms
  other
}

enum PaymentStatus {
  draft
  pending
  approved
  paid
  rejected
}

enum PaymentMethod {
  cash
  bank
}

enum ReimbursementStatus {
  draft
  pending
  approved
  rejected
  paid
}

enum BudgetStatus {
  active
  inactive
}

enum InvoiceType {
  sales
  purchase
}

enum FinanceAccountType {
  cash
  bank
}

enum AccountTransactionType {
  income
  payment
  collection
  reimbursement
  adjustment
}

enum CostSource {
  procurement
  warehouse
  manual
  reimbursement
}

enum DocumentStatus {
  active
  archived
}

enum DocumentFileType {
  pdf
  dwg
  image
  office
}

enum TranslationSourceType {
  document
  drawing
  entity
}

enum TranslationTaskStatus {
  pending
  auto
  manual
  completed
}

enum TranslationVersionSource {
  auto
  manual
}

enum DrawingDiscipline {
  arch
  struct
  mep
  civil
  other
}

enum DrawingStatus {
  draft
  reviewing
  approved
  published
}

enum DrawingFileType {
  dwg
  pdf
  image
}

enum DrawingReviewResult {
  approved
  rejected
}

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  passwordHash String     @map("password_hash")
  name         String
  email        String?
  phone        String?
  locale       Locale     @default(zh)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  userRoles       UserRole[]
  auditLogs       AuditLog[]
  managedProjects Project[]       @relation("ProjectManager")
  projectMembers  ProjectMember[]
  assignedTasks   ProjectTask[]   @relation("TaskAssignee")
  initiatedApprovals ApprovalInstance[] @relation("ApprovalInitiator")
  approvalRecords    ApprovalRecord[]   @relation("ApprovalApprover")
  notifications      Notification[]
  purchaseRequests   PurchaseRequest[] @relation("PurchaseRequester")
  contractRevisions    ContractRevision[] @relation("ContractRevisor")
  reimbursements       Reimbursement[]    @relation("ReimbursementApplicant")
  budgetRevisions      BudgetRevision[]   @relation("BudgetRevisor")
  createdDocuments     Document[]         @relation("DocumentCreator")
  uploadedDocVersions  DocumentVersion[]  @relation("DocumentUploader")
  createdDrawings      Drawing[]          @relation("DrawingCreator")
  uploadedDrawingVersions DrawingVersion[] @relation("DrawingUploader")
  drawingReviews       DrawingReview[]    @relation("DrawingReviewer")
  assignedTranslations TranslationTask[]  @relation("TranslationAssignee")
  createdTranslations  TranslationTask[]  @relation("TranslationCreator")
  translationVersions  TranslationVersion[] @relation("TranslationTranslator")

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  module    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  projectId String?  @map("project_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, projectId])
  @@map("user_roles")
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?     @map("user_id")
  action     AuditAction
  module     String
  resource   String
  resourceId String?     @map("resource_id")
  payload    Json?
  ip         String?
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  key         String   @id
  value       Json
  description String?
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model UserPreference {
  userId            String   @id @map("user_id")
  locale            Locale   @default(zh)
  theme             String   @default("system")
  notificationPrefs Json?    @map("notification_prefs")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("user_preferences")
}

model Project {
  id          String        @id @default(uuid())
  code        String        @unique
  name        String
  nameFr      String?       @map("name_fr")
  location    String?
  status      ProjectStatus @default(planning)
  startDate   DateTime?     @map("start_date") @db.Date
  endDate     DateTime?     @map("end_date") @db.Date
  description String?
  managerId   String        @map("manager_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  manager    User               @relation("ProjectManager", fields: [managerId], references: [id])
  zones      ProjectZone[]
  members    ProjectMember[]
  milestones ProjectMilestone[]
  tasks      ProjectTask[]
  approvals  ApprovalInstance[]
  stockTransactions StockTransaction[]
  materials  Material[]
  purchaseRequests PurchaseRequest[]
  purchaseOrders   PurchaseOrder[]
  warehouses       Warehouse[]
  stockInbounds    StockInbound[]
  stockOutbounds   StockOutbound[]
  stockBalances    StockBalance[]
  stocktakes       Stocktake[]
  contracts        Contract[]
  collections      Collection[]
  incomes          Income[]
  payments         Payment[]
  reimbursements   Reimbursement[]
  budgets          Budget[]
  costs            Cost[]
  invoices         Invoice[]
  documentCategories DocumentCategory[]
  documents        Document[]
  drawings         Drawing[]

  @@index([status])
  @@index([managerId])
  @@map("projects")
}

model ProjectZone {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  name        String
  nameFr      String?   @map("name_fr")
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   ProjectTask[]
  outbounds StockOutbound[]
  drawings  Drawing[]

  @@index([projectId])
  @@map("project_zones")
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectMilestone {
  id          String          @id @default(uuid())
  projectId   String          @map("project_id")
  name        String
  dueDate     DateTime?       @map("due_date") @db.Date
  completedAt DateTime?       @map("completed_at")
  status      MilestoneStatus @default(pending)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_milestones")
}

model ProjectTask {
  id        String     @id @default(uuid())
  projectId String     @map("project_id")
  code      String?
  name      String
  nameFr    String?    @map("name_fr")
  zoneId    String?    @map("zone_id")
  parentId  String?    @map("parent_id")
  startDate     DateTime?  @map("start_date") @db.Date
  endDate       DateTime?  @map("end_date") @db.Date
  laborCount    Int?       @map("labor_count")
  durationDays  Decimal?   @map("duration_days") @db.Decimal(10, 2)
  prerequisites String?
  predecessorId String?    @map("predecessor_id")
  assigneeId    String?    @map("assignee_id")
  showInGantt   Boolean    @default(true) @map("show_in_gantt")
  progress      Int        @default(0)
  status    TaskStatus @default(pending)
  sortOrder Int        @default(0) @map("sort_order")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zone         ProjectZone?  @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  parent       ProjectTask?  @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     ProjectTask[] @relation("TaskHierarchy")
  predecessor  ProjectTask?  @relation("TaskPredecessor", fields: [predecessorId], references: [id], onDelete: SetNull)
  successors   ProjectTask[] @relation("TaskPredecessor")
  assignee     User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([zoneId])
  @@index([parentId])
  @@index([predecessorId])
  @@index([assigneeId])
  @@map("project_tasks")
}

model ApprovalInstance {
  id          String         @id @default(uuid())
  code        String         @unique
  type        ApprovalType
  businessId  String         @map("business_id")
  projectId   String?        @map("project_id")
  initiatorId String         @map("initiator_id")
  status      ApprovalStatus @default(pending)
  currentNode Int            @default(1) @map("current_node")
  metadata    Json?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  initiator User              @relation("ApprovalInitiator", fields: [initiatorId], references: [id])
  project   Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  records   ApprovalRecord[]

  @@index([type])
  @@index([status])
  @@index([initiatorId])
  @@index([projectId])
  @@index([businessId, type])
  @@map("approval_instances")
}

model ApprovalRecord {
  id         String               @id @default(uuid())
  instanceId String               @map("instance_id")
  node       Int
  approverId String               @map("approver_id")
  action     ApprovalRecordAction
  comment    String?
  actedAt    DateTime             @default(now()) @map("acted_at")

  instance ApprovalInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  approver User             @relation("ApprovalApprover", fields: [approverId], references: [id])

  @@index([instanceId])
  @@index([approverId])
  @@map("approval_records")
}

model ApprovalTemplate {
  id        String       @id @default(uuid())
  type      ApprovalType
  name      String
  nodes     Json
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@index([type, isActive])
  @@map("approval_templates")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  content   String
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

model MaterialCategory {
  id          String             @id @default(uuid())
  code        String             @unique
  name        String
  discipline  MaterialDiscipline @default(general)
  description String?
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")

  materials Material[]

  @@index([discipline])
  @@map("material_categories")
}

model Material {
  id                     String    @id @default(uuid())
  code                   String
  name                   String
  spec                   String?
  brand                  String?
  model                  String?
  unit                   String
  categoryId             String    @map("category_id")
  projectId              String    @map("project_id")
  storageLocation        String?   @map("storage_location")
  warehouseId            String?   @map("warehouse_id")
  stock                  Decimal   @default(0) @db.Decimal(18, 4)
  minStock               Decimal?  @map("min_stock") @db.Decimal(18, 4)
  purchasePriceAmount    Decimal?  @map("purchase_price_amount") @db.Decimal(18, 4)
  purchasePriceCurrency  String?   @map("purchase_price_currency") @db.Char(3)
  imageUrl               String?   @map("image_url")
  supplierId             String?   @map("supplier_id")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  category        MaterialCategory      @relation(fields: [categoryId], references: [id])
  project         Project               @relation(fields: [projectId], references: [id])
  warehouse       Warehouse?            @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  supplier        Supplier?             @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  priceHistory    MaterialPriceHistory[]
  qrcode          MaterialQrcode?
  stockTransactions StockTransaction[]
  purchaseRequestItems PurchaseRequestItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  quotations           Quotation[]
  stockItems           StockItem[]
  stockBalances        StockBalance[]
  stocktakeItems       StocktakeItem[]

  @@unique([projectId, code])
  @@index([categoryId])
  @@index([projectId])
  @@index([name])
  @@map("materials")
}

model MaterialPriceHistory {
  id          String   @id @default(uuid())
  materialId  String   @map("material_id")
  amount      Decimal  @db.Decimal(18, 4)
  currency    String   @db.Char(3)
  supplierId  String?  @map("supplier_id")
  effectiveAt DateTime @default(now()) @map("effective_at")
  createdAt   DateTime @default(now()) @map("created_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([materialId, effectiveAt])
  @@map("material_price_history")
}

model MaterialQrcode {
  id         String   @id @default(uuid())
  materialId String   @unique @map("material_id")
  qrcodeUrl  String   @map("qrcode_url")
  payload    String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@map("material_qrcodes")
}

model StockTransaction {
  id            String               @id @default(uuid())
  materialId    String               @map("material_id")
  type          StockTransactionType
  quantity      Decimal              @db.Decimal(18, 4)
  balanceAfter  Decimal?             @map("balance_after") @db.Decimal(18, 4)
  reference     String?
  warehouseId   String?              @map("warehouse_id")
  projectId     String?              @map("project_id")
  createdAt     DateTime             @default(now()) @map("created_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Restrict)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  @@index([materialId])
  @@index([warehouseId])
  @@index([projectId])
  @@index([createdAt])
  @@map("stock_transactions")
}

model Supplier {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  contact   String?
  phone     String?
  email     String?
  address   String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  materials      Material[]
  purchaseOrders PurchaseOrder[]
  quotations     Quotation[]

  @@index([name])
  @@map("suppliers")
}

model PurchaseRequest {
  id          String                @id @default(uuid())
  code        String                @unique
  projectId   String                @map("project_id")
  requesterId String                @map("requester_id")
  status      PurchaseRequestStatus @default(draft)
  remark      String?
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  deletedAt   DateTime?             @map("deleted_at")

  project    Project               @relation(fields: [projectId], references: [id])
  requester  User                  @relation("PurchaseRequester", fields: [requesterId], references: [id])
  items      PurchaseRequestItem[]
  orders     PurchaseOrder[]
  quotations Quotation[]

  @@index([projectId])
  @@index([status])
  @@index([requesterId])
  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id         String  @id @default(uuid())
  requestId  String  @map("request_id")
  materialId String  @map("material_id")
  quantity   Decimal @db.Decimal(18, 4)
  unit       String

  request  PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  material Material        @relation(fields: [materialId], references: [id])

  @@index([requestId])
  @@map("purchase_request_items")
}

model PurchaseOrder {
  id            String              @id @default(uuid())
  code          String              @unique
  projectId     String              @map("project_id")
  supplierId    String              @map("supplier_id")
  requestId     String?             @map("request_id")
  totalAmount   Decimal             @map("total_amount") @db.Decimal(18, 4)
  totalCurrency String              @map("total_currency") @db.Char(3)
  status        PurchaseOrderStatus @default(draft)
  orderedAt     DateTime?           @map("ordered_at")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  deletedAt     DateTime?           @map("deleted_at")

  project  Project          @relation(fields: [projectId], references: [id])
  supplier Supplier         @relation(fields: [supplierId], references: [id])
  request  PurchaseRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  items    PurchaseOrderItem[]
  inbounds StockInbound[]
  payments Payment[]

  @@index([projectId])
  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                String  @id @default(uuid())
  orderId           String  @map("order_id")
  materialId        String  @map("material_id")
  quantity          Decimal @db.Decimal(18, 4)
  unit              String
  unitPriceAmount   Decimal @map("unit_price_amount") @db.Decimal(18, 4)
  unitPriceCurrency String  @map("unit_price_currency") @db.Char(3)

  order    PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  material Material      @relation(fields: [materialId], references: [id])

  @@index([orderId])
  @@map("purchase_order_items")
}

model Quotation {
  id         String          @id @default(uuid())
  code       String          @unique
  supplierId String          @map("supplier_id")
  requestId  String?         @map("request_id")
  materialId String?         @map("material_id")
  amount     Decimal         @db.Decimal(18, 4)
  currency   String          @db.Char(3)
  status     QuotationStatus @default(draft)
  remark     String?
  quotedAt   DateTime?       @map("quoted_at")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  supplier Supplier         @relation(fields: [supplierId], references: [id])
  request  PurchaseRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  material Material?        @relation(fields: [materialId], references: [id], onDelete: SetNull)

  @@index([supplierId])
  @@index([requestId])
  @@map("quotations")
}

model Warehouse {
  id        String          @id @default(uuid())
  code      String          @unique
  name      String
  projectId String          @map("project_id")
  address   String?
  status    WarehouseStatus @default(active)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  deletedAt DateTime?       @map("deleted_at")

  project        Project          @relation(fields: [projectId], references: [id])
  materials      Material[]
  inbounds       StockInbound[]
  outbounds      StockOutbound[]
  balances       StockBalance[]
  stocktakes     Stocktake[]
  stockTransactions StockTransaction[]

  @@index([projectId])
  @@map("warehouses")
}

model StockInbound {
  id              String              @id @default(uuid())
  code            String              @unique
  warehouseId     String              @map("warehouse_id")
  projectId       String              @map("project_id")
  purchaseOrderId String?             @map("purchase_order_id")
  type            InboundType
  status          StockDocumentStatus @default(draft)
  inboundAt       DateTime?           @map("inbound_at")
  remark          String?
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  project       Project        @relation(fields: [projectId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  items         StockItem[]

  @@index([warehouseId])
  @@index([projectId])
  @@index([status])
  @@map("stock_inbound")
}

model StockOutbound {
  id          String              @id @default(uuid())
  code        String              @unique
  warehouseId String              @map("warehouse_id")
  projectId   String              @map("project_id")
  zoneId      String?             @map("zone_id")
  type        OutboundType
  status      StockDocumentStatus @default(draft)
  outboundAt  DateTime?           @map("outbound_at")
  remark      String?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  warehouse Warehouse   @relation(fields: [warehouseId], references: [id])
  project   Project     @relation(fields: [projectId], references: [id])
  zone      ProjectZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  items     StockItem[]

  @@index([warehouseId])
  @@index([projectId])
  @@index([status])
  @@map("stock_outbound")
}

model StockItem {
  id         String  @id @default(uuid())
  inboundId  String? @map("inbound_id")
  outboundId String? @map("outbound_id")
  materialId String  @map("material_id")
  quantity   Decimal @db.Decimal(18, 4)
  unit       String

  inbound  StockInbound?  @relation(fields: [inboundId], references: [id], onDelete: Cascade)
  outbound StockOutbound? @relation(fields: [outboundId], references: [id], onDelete: Cascade)
  material Material       @relation(fields: [materialId], references: [id])

  @@index([inboundId])
  @@index([outboundId])
  @@map("stock_items")
}

model StockBalance {
  id          String  @id @default(uuid())
  warehouseId String  @map("warehouse_id")
  materialId  String  @map("material_id")
  projectId   String  @map("project_id")
  quantity    Decimal @default(0) @db.Decimal(18, 4)
  updatedAt   DateTime @updatedAt @map("updated_at")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  material  Material  @relation(fields: [materialId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])

  @@unique([warehouseId, materialId, projectId])
  @@index([projectId])
  @@map("stock_balances")
}

model Stocktake {
  id          String              @id @default(uuid())
  code        String              @unique
  warehouseId String              @map("warehouse_id")
  projectId   String              @map("project_id")
  status      StockDocumentStatus @default(draft)
  remark      String?
  confirmedAt DateTime?           @map("confirmed_at")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  warehouse Warehouse       @relation(fields: [warehouseId], references: [id])
  project   Project         @relation(fields: [projectId], references: [id])
  items     StocktakeItem[]

  @@index([warehouseId])
  @@index([projectId])
  @@map("stocktakes")
}

model StocktakeItem {
  id              String  @id @default(uuid())
  stocktakeId     String  @map("stocktake_id")
  materialId      String  @map("material_id")
  bookQuantity    Decimal @map("book_quantity") @db.Decimal(18, 4)
  countedQuantity Decimal @map("counted_quantity") @db.Decimal(18, 4)
  unit            String

  stocktake Stocktake @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
  material  Material  @relation(fields: [materialId], references: [id])

  @@index([stocktakeId])
  @@map("stocktake_items")
}

model Contract {
  id                      String         @id @default(uuid())
  code                    String         @unique
  name                    String
  nameFr                  String?        @map("name_fr")
  projectId               String         @map("project_id")
  partyA                  String         @map("party_a")
  partyB                  String         @map("party_b")
  amountAmount            Decimal        @map("amount_amount") @db.Decimal(18, 4)
  amountCurrency          String         @map("amount_currency") @db.Char(3)
  type                    ContractType
  signedAt                DateTime?      @map("signed_at") @db.Date
  startDate               DateTime?      @map("start_date") @db.Date
  endDate                 DateTime?      @map("end_date") @db.Date
  status                  ContractStatus @default(draft)
  collectedAmountAmount   Decimal        @default(0) @map("collected_amount_amount") @db.Decimal(18, 4)
  collectedAmountCurrency String?        @map("collected_amount_currency") @db.Char(3)
  attachmentUrl           String?        @map("attachment_url")
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")
  deletedAt               DateTime?      @map("deleted_at")

  project   Project            @relation(fields: [projectId], references: [id])
  revisions ContractRevision[]
  collections Collection[]
  incomes     Income[]
  payments    Payment[]
  invoices    Invoice[]

  @@index([projectId])
  @@index([status])
  @@index([type])
  @@map("contracts")
}

model ContractRevision {
  id          String             @id @default(uuid())
  contractId  String             @map("contract_id")
  changeType  ContractChangeType @map("change_type")
  before      Json
  after       Json
  reason      String?
  changedById String             @map("changed_by_id")
  createdAt   DateTime           @default(now()) @map("created_at")

  contract  Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  changedBy User     @relation("ContractRevisor", fields: [changedById], references: [id])

  @@index([contractId])
  @@map("contract_revisions")
}

model Collection {
  id             String             @id @default(uuid())
  code           String             @unique
  contractId     String             @map("contract_id")
  projectId      String             @map("project_id")
  amountAmount   Decimal            @map("amount_amount") @db.Decimal(18, 4)
  amountCurrency String             @map("amount_currency") @db.Char(3)
  collectedAt    DateTime           @map("collected_at") @db.Date
  accountType    FinanceAccountType @map("account_type")
  accountId      String             @map("account_id")
  remark         String?
  createdAt      DateTime           @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id])
  project  Project  @relation(fields: [projectId], references: [id])

  @@index([contractId])
  @@index([projectId])
  @@map("collections")
}

model Income {
  id             String   @id @default(uuid())
  code           String   @unique
  projectId      String   @map("project_id")
  contractId     String?  @map("contract_id")
  amountAmount   Decimal  @map("amount_amount") @db.Decimal(18, 4)
  amountCurrency String   @map("amount_currency") @db.Char(3)
  receivedAt     DateTime @map("received_at") @db.Date
