model DrawingVersion {
  id           String          @id @default(uuid())
  drawingId    String          @map("drawing_id")
  version      Int
  fileUrl      String          @map("file_url")
  fileName     String          @map("file_name")
  fileType     DrawingFileType @map("file_type")
  fileSize     Int?            @map("file_size")
  uploadedById String          @map("uploaded_by_id")
  uploadedAt   DateTime        @default(now()) @map("uploaded_at")

  drawing    Drawing @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("DrawingUploader", fields: [uploadedById], references: [id])

  @@unique([drawingId, version])
  @@index([drawingId])
  @@map("drawing_versions")
}

