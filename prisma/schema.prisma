  sourceId   String                @map("source_id")
  sourceLang Locale                @map("source_lang")
  targetLang Locale                @map("target_lang")
  status     TranslationTaskStatus @default(pending)
  assigneeId String?               @map("assignee_id")
  searchText String?               @map("search_text")
  createdById String?              @map("created_by_id")
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")

  assignee  User?                @relation("TranslationAssignee", fields: [assigneeId], references: [id])
  createdBy User?                @relation("TranslationCreator", fields: [createdById], references: [id])
