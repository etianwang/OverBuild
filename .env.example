# Database (client 与库均使用 UTF-8，支持中文/法语/英文)
DATABASE_URL="postgresql://overbuild:overbuild@localhost:5432/overbuild?schema=public&client_encoding=UTF8"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="2h"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# API
API_PORT=3001
API_URL="http://localhost:3001"

# Web
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# DeepL (Free API keys end with :fx → uses api-free.deepl.com)
DEEPL_AUTH_KEY=""
# Optional override, e.g. https://api-free.deepl.com or https://api.deepl.com
# DEEPL_API_URL=""
