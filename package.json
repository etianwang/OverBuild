{
  "name": "overbuild",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "npm run lint -w @overbuild/api && npm run lint -w @overbuild/web",
    "build": "npm run build -w @overbuild/api && npm run build -w @overbuild/web",
    "test": "npm run test -w @overbuild/api && npm run test -w @overbuild/web",
    "test:e2e": "npm run test:e2e -w @overbuild/api",
    "dev:api": "npm run dev -w @overbuild/api",
    "dev:web": "npm run dev -w @overbuild/web",
    "dev:web:clean": "node -e \"require('fs').rmSync('apps/web/.next',{recursive:true,force:true})\" && npm run dev:web",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:fix-text": "tsx prisma/fix-text-content.ts",
    "db:check-encoding": "powershell -ExecutionPolicy Bypass -File scripts/check-encoding.ps1",
    "db:setup": "npm run db:generate && npx prisma migrate deploy && npm run db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:build": "docker compose build",
    "test:local": "powershell -ExecutionPolicy Bypass -File scripts/test-local.ps1",
    "test:deepl": "node scripts/test-deepl.mjs",
    "docker:init": "npm run docker:up && npm run db:setup"
  },
  "devDependencies": {
    "bcrypt": "^6.0.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
